# ============================================================
# frapto_transp — variáveis de ambiente
# Copie para .env (local) ou configure no Railway (produção).
# ============================================================

# ---------- CRÍTICAS (o boot falha em produção sem elas) ----------

# Banco MySQL/TiDB (Drizzle). Ex.: mysql://user:pass@host:4000/frapto_transp
DATABASE_URL=

# Segredo do JWT de sessão. >= 32 caracteres.
# Gere com: openssl rand -base64 32
JWT_SECRET=

# URL pública do app (sem barra no fim). Ex.: https://frapto-transp.up.railway.app
APP_BASE_URL=

# Email que, ao logar pela 1ª vez, recebe papel de admin.
OWNER_EMAIL=

# Stripe (paywall / assinatura). Crie o produto/preço no painel do Stripe.
# STRIPE_SECRET_KEY:   sk_live_... (ou sk_test_...)
# STRIPE_PRICE_ID:     price_... do plano mensal (R$ 57)
# STRIPE_WEBHOOK_SECRET: whsec_... do endpoint /api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 (upload de documentos). Token com escopo só no bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ---------- OPCIONAIS ----------

# Assistente de IA de frota. NÃO é mais obrigatório aqui: um admin pode
# configurar provedor (Claude/GPT/compatível), chave e modelo direto na tela
# Configurações do app. Se definido, serve de fallback (provedor Anthropic).
# ANTHROPIC_API_KEY=

# Porta (Railway injeta automaticamente; padrão 3000 em local).
# PORT=3000

# NODE_ENV=production   # definido pelo Railway em produção
